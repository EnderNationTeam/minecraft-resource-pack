{
    "files.associations": {
        "pack.mcmeta": "json"
    },
    "json.schemas": [
        {
            "fileMatch": ["bedrock/**/*.json"],
            "url": "./.vscode/schemas/bedrock-schema.json"
        },
        {
            "fileMatch": ["**/pack.mcmeta"],
            "url": "./.vscode/schemas/minecraft-pack-mcmeta.json"
        },
        {
            "fileMatch": ["**/assets/*/sounds.json"],
            "url": "./.vscode/schemas/sounds.json"
        },
        {
            "fileMatch": ["**/assets/*/lang/*.json"],
            "url": "./.vscode/schemas/minecraft-lang.json"
        },
        {
            "fileMatch": ["java/assets/*/items/**/*.json"],
            "url": "./.vscode/schemas/java-item-definition.schema.json"
        },
        {
            "fileMatch": ["java/assets/*/models/**/*.json"],
            "url": "./.vscode/schemas/java-model.schema.json"
        },
        {
            "fileMatch": ["geysermc/**/*.json"],
            "url": "./.vscode/schemas/geysermc-mappings.schema.json"
        }
    ]
}
